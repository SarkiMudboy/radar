# PostgreSQL connection string (local Docker, Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/radar"

# NextAuth.js — https://next-auth.js.org/configuration/options#secret
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# App URL (no trailing slash). Required for OAuth redirects in production.
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth App — https://github.com/settings/developers
GITHUB_ID=""
GITHUB_SECRET=""
